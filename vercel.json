{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build:frontend",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!.*\\.(js|css|map|json|png|jpg|jpeg|gif|svg|ico|webp|avif|woff|woff2|ttf|eot)$).*)",
      "destination": "/index.html"
    }
  ]
}
